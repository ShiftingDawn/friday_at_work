generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(uuid())
  username             String                @unique
  password             String
  sessions             Session[]
  workspaces           Workspace[]
  workspacePermissions WorkspacePermission[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model Workspace {
  id           String                @id @default(uuid())
  name         String
  ownerId      String
  owner        User                  @relation(fields: [ownerId], references: [id])
  people       Person[]
  drinks       Drink[]
  consumptions Consumption[]
  permissions  WorkspacePermission[]

  @@unique([name, ownerId])
  @@map("workspaces")
}

enum Permission {
  READ
  WRITE
  ADMIN
}

model WorkspacePermission {
  id          String     @id @default(uuid())
  permission  Permission @default(READ)
  workspaceId String
  userId      String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  user        User       @relation(fields: [userId], references: [id])

  @@map("workspace_permissions")
}

model Person {
  id           String        @id @default(uuid())
  workspaceId  String
  name         String
  reset        DateTime?
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  consumptions Consumption[]

  @@map("people")
}

model Drink {
  id           String        @id @default(uuid())
  workspaceId  String
  name         String
  price        Int
  hidden       Boolean       @default(false)
  modifiedAt   DateTime      @default(now())
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  consumptions Consumption[]
  restocks     Restock[]

  @@map("drinks")
}

model Consumption {
  id          String    @id @default(uuid())
  workspaceId String
  personId    String
  drinkId     String
  price       Int
  timestamp   DateTime  @default(now())
  person      Person    @relation(fields: [personId], references: [id])
  drink       Drink     @relation(fields: [drinkId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@map("consumptions")
}

model Restock {
  id        String   @id @default(uuid())
  drinkId   String
  amount    Int
  timestamp DateTime @default(now())
  drink     Drink    @relation(fields: [drinkId], references: [id])

  @@map("restocks")
}
